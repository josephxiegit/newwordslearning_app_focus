                    <!-- ==================== зҠ¶жҖҒж Ҹе’ҢUIй…ҚзҪ® ==================== -->
            <!-- еӨҙйғЁе®үе…ЁеҢәеҹҹпјҡзҠ¶жҖҒж ҸдёҚиҰҶзӣ–WebViewеҶ…е®№ -->
            <preference name="StatusBarOverlaysWebView" value="false" />

            <!-- ==================== зҪ‘з»ңе®үе…Ёй…ҚзҪ® ==================== -->
            <!-- еә”з”ЁзҪ‘з»ңе®үе…Ёй…ҚзҪ®ж–Үд»¶пјҢе…Ғи®ёзү№е®ҡеҹҹеҗҚдҪҝз”ЁжҳҺж–ҮHTTP -->
            <edit-config file="AndroidManifest.xml" target="/manifest/application" mode="merge">
                <application android:networkSecurityConfig="@xml/network_security_config" />
            </edit-config>

            <!-- WebViewе®үе…ЁеҹҹеҗҚиҰҶзӣ– -->
            <preference name="webview-safe-domain-override" value="true" />

            <!-- е…Ғи®ёеә”з”ЁеҸ‘иө·HTTPпјҲйқһHTTPSпјүиҜ·жұӮ -->
            <preference name="android-usesCleartextTraffic" value="true" />
            <edit-config file="AndroidManifest.xml" target="/manifest/application" mode="merge">
                <application android:usesCleartextTraffic="true" />
            </edit-config>

            <!-- ==================== еә”з”Ёжқғйҷҗй…ҚзҪ® ==================== -->
            <!-- дә’иҒ”зҪ‘жқғйҷҗпјҡеҝ…йЎ»жңүпјҢеҗҰеҲҷж— жі•и®ҝй—®зҪ‘з»ң -->
            <uses-permission android:name="android.permission.INTERNET" /> 

            <!-- зҪ‘з»ңзҠ¶жҖҒжқғйҷҗпјҡжЈҖжҹҘи®ҫеӨҮжҳҜеҗҰиҝһжҺҘеҲ°зҪ‘з»ң -->
            <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

            <!-- зІҫзЎ®дҪҚзҪ®жқғйҷҗпјҲеҰӮжһңеә”з”ЁдёҚйңҖиҰҒдҪҚзҪ®пјҢеҸҜеҲ йҷӨпјү -->
            <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />

            <!-- зІ—з•ҘдҪҚзҪ®жқғйҷҗпјҲеҰӮжһңеә”з”ЁдёҚйңҖиҰҒдҪҚзҪ®пјҢеҸҜеҲ йҷӨпјү -->
            <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

            <!-- Android 11+ еә”з”ЁеҸҜи§ҒжҖ§пјҡеЈ°жҳҺеә”з”ЁеҸҜд»ҘжҹҘиҜўе…¶д»–еә”з”Ё -->
            <edit-config file="AndroidManifest.xml" target="/manifest" mode="merge">
                <queries>
                    <intent>
                        <action android:name="android.intent.action.MAIN" />
                        <category android:name="android.intent.category.LAUNCHER" />
                    </intent>
                </queries>
            </edit-config>

            <!-- ==================== ж–Үд»¶еӯҳеӮЁй…ҚзҪ® ==================== -->
            <!-- еә”з”Ёж–Үд»¶еӯҳеӮЁдҪҚзҪ®пјҡInternalиЎЁзӨәдҪҝз”ЁеҶ…йғЁеӯҳеӮЁ -->
            <preference name="AndroidPersistentFileLocation" value="Internal" />

            <!-- ==================== дё“з”ЁжңәжЁЎејҸй…ҚзҪ®пјҲзҰҒз”Ёзі»з»ҹдәӨдә’пјү ==================== -->
            <!-- зҰҒз”Ёе…ЁеұҸжүӢеҠҝе’ҢдёӢжӢүиҸңеҚ•пјҡйҖҡиҝҮејәеҲ¶е…ЁеұҸжҳҫзӨә -->
            <preference name="Fullscreen" value="true" />

            <!-- зҰҒз”Ёиҝ”еӣһеҜјиҲӘпјҡйҳІжӯўз”ЁжҲ·йҖҡиҝҮзі»з»ҹжүӢеҠҝиҝ”еӣһ -->
            <preference name="DisallowOverscroll" value="true" />
    </platform>
    </widget>
